# Claude Code Settings Environment Variables
# Copy this file to settings.env and fill in your values
# Then run: ./install.sh

# Required: Your API authentication token
ANTHROPIC_AUTH_TOKEN=your_token_here

# Required: API base URL (use Anthropic's default or a compatible endpoint)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Override default models
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_MODEL=
ANTHROPIC_REASONING_MODEL=
